# Unified Neuro Platform - frontend environment.
# Copy to .env.local and fill in. Never commit real values.

# Supabase (anon key only in the browser; service role stays server-side).
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Unified FastAPI backend base URL.
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000

# Server-only (Next route handlers / admin ops).
SUPABASE_SERVICE_ROLE_KEY=

# Email (server-only, for admin user creation).
EMAIL_HOST=
EMAIL_PORT=
EMAIL_USER=
EMAIL_PASSWORD=
