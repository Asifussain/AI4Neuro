# ---------------------------------------------------------------------------
# AI4Neuro frontend environment. Copy to `.env.local` and fill in real values.
# ---------------------------------------------------------------------------

# Supabase project (browser-safe anon key). Required for auth/session.
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# FastAPI backend base URL. Every dashboard/analysis read goes through this
# service (never direct-to-Supabase for analysis data). If dashboards show
# "Cannot reach the API server" / "Failed to fetch", the backend at this URL
# is not running or this value is wrong.
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000

# ---------------------------------------------------------------------------
# Server-only (used by the /api/admin/create-user route). Without these, user
# creation still works but the credential email cannot be sent and the UI shows
# "Email delivery failed — please share these credentials manually."
# ---------------------------------------------------------------------------
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your-smtp-user@example.com
EMAIL_PASSWORD=your-smtp-app-password
