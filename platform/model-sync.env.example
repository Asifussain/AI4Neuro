# Cloudflare R2 / S3-compatible credentials for platform/scripts/sync_models_from_object_storage.sh.
# Copy to model-sync.env (gitignored) and fill in real values. Never commit
# real credentials — see platform/.gitignore.
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=auto

# Current shared model artifact store.
MODEL_BUCKET=ai4neuro-models
MODEL_PREFIX=ai4neuro
MODEL_ENDPOINT_URL=https://<account-id>.r2.cloudflarestorage.com
