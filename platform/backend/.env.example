# Unified Neuro Platform - backend environment.
# Copy to .env and fill in. .env is gitignored; never commit real secrets.

# ---- Application ----
APP_ENV=development
API_HOST=0.0.0.0
API_PORT=8000
CORS_ORIGINS=http://localhost:3000

# ---- Supabase ----
# The backend uses the SERVICE ROLE key (server-side only, bypasses RLS).
# SUPABASE_JWT_SECRET is used to verify access tokens sent by the frontend.
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_JWT_SECRET=

# ---- Storage buckets ----
RAW_FILES_BUCKET=raw-files
REPORT_ASSETS_BUCKET=report-assets
REPORTS_BUCKET=reports
VIEWER_SLICES_BUCKET=viewer-slices

# ---- Background jobs ----
JOB_BACKEND=local
LOCAL_JOB_MAX_WORKERS=2

# ---- Uploads ----
LOCAL_TMP_DIR=/tmp/neuro-platform
MAX_UPLOAD_MB=512

# ---- Auth ----
# Keep true for local dev before full auth is wired; MUST be false in production.
AUTH_DEV_BYPASS=true

# ---- Pipeline toggles ----
# MRI: mock model on hosts without ConViT weights / CAT12 / MATLAB Runtime (e.g. Linux).
USE_MOCK_MODEL=true
USE_CAT12_PREPROCESSING=false

# ---- EEG pipeline (used from Phase 2 onward) ----
# EEG_MODEL_ROOT=
# EEG_USE_GPU=false

# ---- MRI pipeline (used from Phase 3 onward) ----
# CONVIT_CHECKPOINT_PATH=
# CAT12_ROOT=
# MCR_ROOT=
# CAT12_EXE=
# MRI_USE_GPU=false
