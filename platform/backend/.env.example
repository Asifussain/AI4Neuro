# Unified Neuro Platform - backend environment.
# Copy to .env and fill in. .env is gitignored; never commit real secrets.

# ---- Application ----
APP_ENV=development
API_HOST=0.0.0.0
API_PORT=8000
CORS_ORIGINS=http://localhost:3000

# ---- Supabase ----
# The backend uses a server-only elevated key. Prefer the newer Supabase
# `sb_secret_...` key. Legacy `service_role` JWT keys still work but should only
# be used as a fallback.
#
# SUPABASE_JWT_SECRET is optional for projects still issuing legacy HS256 user
# tokens. Newer Supabase projects use asymmetric JWT signing keys; the backend
# verifies those automatically through the project's JWKS endpoint.
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_JWT_SECRET=

# ---- Storage buckets ----
RAW_FILES_BUCKET=raw-files
REPORT_ASSETS_BUCKET=report-assets
REPORTS_BUCKET=reports
VIEWER_SLICES_BUCKET=viewer-slices

# ---- Background jobs ----
JOB_BACKEND=local
LOCAL_JOB_MAX_WORKERS=2

# ---- Uploads ----
LOCAL_TMP_DIR=/tmp/neuro-platform
MAX_UPLOAD_MB=512

# ---- Auth ----
# Only takes effect when APP_ENV=development (enforced at startup — the app
# refuses to boot if this is true with any other APP_ENV). Set to true only
# for local dev before full auth is wired; MUST stay false everywhere else.
AUTH_DEV_BYPASS=false

# ---- EEG pipeline ----
# Defaults already point at ../../Alzheimer-Detection/backend/SIDDHI (relative to
# this repo layout), so these are only needed if you move/containerize the backend.
# EEG_SIDDHI_DIR=
# EEG_CHECKPOINT_ROOT=
# EEG_REFERENCE_DIR=
# EEG_USE_GPU=false

# ---- MRI pipeline ----
# The pipeline takes the uploaded scan as already preprocessed (no CAT12 step)
# and is multiclass-only (CN/MCI/AD). A real ConViT checkpoint is required —
# without one, MRI analysis jobs fail explicitly instead of returning mock
# predictions.
# CONVIT_CHECKPOINT_PATH=
# MRI_USE_GPU=false
