# Seed script environment. Copy to .env and fill in. Never commit real values.
# Both are found in Supabase Dashboard → Project Settings → API.

# Project URL (e.g. https://abcdxyz.supabase.co)
SUPABASE_URL=

# service_role key (SECRET — full admin access; only ever used server-side/CLI)
SUPABASE_SERVICE_ROLE_KEY=
